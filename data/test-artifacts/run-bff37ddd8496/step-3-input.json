{
  "agent": "weatherAgent",
  "provider": "mock",
  "jsonMode": false,
  "tools": [
    {
      "name": "lookupWeather",
      "description": "Fetch current weather for a city.",
      "input_schema": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string"
          }
        },
        "required": [
          "city"
        ]
      }
    }
  ],
  "messages": [
    {
      "role": "system",
      "content": "Use tools to answer."
    },
    {
      "role": "user",
      "content": "Weather in X?"
    },
    {
      "role": "assistant",
      "content": [
        {
          "type": "tool_use",
          "id": "call-1",
          "name": "lookupWeather",
          "input": {
            "city": "X"
          }
        }
      ]
    },
    {
      "role": "tool",
      "content": [
        {
          "type": "tool_result",
          "tool_use_id": "call-1",
          "content": "{\"city\":\"X\",\"tempC\":18,\"sky\":\"clear\"}"
        }
      ]
    }
  ]
}