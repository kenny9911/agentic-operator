{
  "agent": "weatherAgent",
  "provider": "mock",
  "jsonMode": false,
  "tools": [
    {
      "name": "lookupWeather",
      "description": "Fetch current weather for a city.",
      "input_schema": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string"
          }
        },
        "required": [
          "city"
        ]
      }
    }
  ],
  "messages": [
    {
      "role": "system",
      "content": "Use tools to answer."
    },
    {
      "role": "user",
      "content": "Weather in X?"
    }
  ]
}