# --- Runtime mode ---
NODE_ENV=development
AUTH_MODE=dev           # dev | production — dev bypasses magic-link, uses seeded admin

# --- SQLite ---
DATABASE_URL=file:./agentic.db

# --- Inngest ---
INNGEST_DEV=1
INNGEST_EVENT_KEY=local-dev-event-key
INNGEST_SIGNING_KEY=local-dev-signing-key
INNGEST_BASE_URL=http://localhost:8288

# --- Magic-link auth (production only) ---
RESEND_API_KEY=
AUTH_FROM_EMAIL=noreply@example.com
AUTH_SESSION_SECRET=change-me-in-production-32-bytes-min

# --- File storage roots ---
AGENTIC_LOGS_DIR=./logs
AGENTIC_ARTIFACTS_DIR=./artifacts

# --- Webhook HMAC secrets (per provider) ---
WEBHOOK_HMAC_SECRET_DEFAULT=local-dev-hmac

# --- LLM gateway defaults ---
# Falls back to `mock` if unset; mock never makes a real network call.
LLM_DEFAULT_PROVIDER=mock
LLM_DEFAULT_MODEL=
LLM_REQUEST_TIMEOUT_MS=60000

# --- LLM provider API keys (leave blank for providers you don't use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_REFERRER=http://localhost:3500
OPENROUTER_APP_TITLE=Agentic Operator
GOOGLE_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# Azure OpenAI (needs all three)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=

# Custom OpenAI-compatible (e.g. self-hosted vLLM)
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
