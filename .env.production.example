# Agentic Operator — production environment contract (P4-OPS-08).
#
# Every variable the runtime reads from `process.env` is listed here with
# a description and the safe production default. Variables flagged
# **REQUIRED** must be set for the API/web/inngest stack to boot
# correctly; leaving them at the placeholder will fail health checks.
#
# Validation:
#   * `docker compose --env-file .env.production config` will substitute
#     defaults and complain about any unset *required* var.
#   * `GET /health` returns 503 if the LLM gateway, SQLite, or inngest
#     subsystem reports `ok: false`.
#
# Secrets rotation: see `docs/RUNBOOK.md §3`.

# ─── Runtime mode ────────────────────────────────────────────────────────
# REQUIRED — must be "production" outside dev/test.
NODE_ENV=production

# Auth mode. "production" forces bearer-token authentication for every
# /v1/* route. "dev" unlocks the AGENTIC_DEV_TENANT fallback and is for
# local sandboxes only. CI sets AUTH_MODE=dev + a system tenant so unit
# tests can issue requests without minting a real api_tokens row.
AUTH_MODE=production

# ─── HTTP surface ────────────────────────────────────────────────────────
# Port the API process listens on inside the container. Compose maps this
# to the host via `API_PORT` (default 3501 → 3501).
PORT=3501
HOST=0.0.0.0

# Where the web app is served from. Used by the API's CORS allow-list so
# browser sessions can call /v1/*. Must include scheme + host (+ port if
# non-standard).
WEB_ORIGIN=https://operator.example.com
AGENTIC_WEB_ORIGIN=https://operator.example.com

# Public URL of the API. The web app uses this for SSR rewrites and the
# Next.js build embeds it into beforeFiles rewrites at build time.
AGENTIC_API_URL=https://api.operator.example.com

# Inbound rate limit (per minute, per authenticated tenant or per remote
# IP when unauthenticated). Set to a high value or disable via
# AGENTIC_RATE_LIMIT_DISABLED=1 if you front the API with a reverse
# proxy that already rate-limits.
AGENTIC_RATE_LIMIT_PER_MIN=100
# AGENTIC_RATE_LIMIT_DISABLED=1

# Per-request body cap. Tenants that ship large code bundles (see
# `/v1/tenants/:slug/code`) may need this lifted to 5–10 MB. Bytes.
AGENTIC_BODY_LIMIT_BYTES=1048576

# SIGTERM drain window before `process.exit(1)` is forced. Bump this if
# your slowest in-flight handler legitimately takes > 30s.
AGENTIC_SHUTDOWN_TIMEOUT_MS=30000

# Optional override: pino log level (one of trace/debug/info/warn/error/
# fatal). Default `info` is right for production; bump to `warn` if log
# volume is a budget pain.
LOG_LEVEL=info

# Optional: deployed git SHA / image tag, surfaced on `/health.version`.
# CI usually sets this from the commit; leave blank for "dev".
# GIT_SHA=

# ─── SQLite ──────────────────────────────────────────────────────────────
# Absolute path inside the container. The compose file mounts
# `./data` → `/app/data`, so the default places agentic.db on the volume.
DATABASE_URL=file:/app/data/agentic.db

# Optional override for the better-sqlite3 native binding location. The
# resolver auto-walks node_modules — set this only when running outside
# the expected pnpm layout (e.g. a custom packaging).
# AGENTIC_SQLITE_BINDING=/app/node_modules/better-sqlite3/build/Release/better_sqlite3.node

# ─── File storage roots ──────────────────────────────────────────────────
# All paths are inside the container; persist via the `agentic-data`
# volume. Tenant-specific code lives under AGENTIC_TENANTS_DIR; manifests
# live under AGENTIC_MODELS_DIR (typically a read-only bind mount).
AGENTIC_DATA_DIR=/app/data
AGENTIC_MODELS_DIR=/app/models
AGENTIC_LOGS_DIR=/app/data/logs
AGENTIC_ARTIFACTS_DIR=/app/data/artifacts
AGENTIC_TENANTS_DIR=/app/data/tenants

# Run-log + artifact retention (in days). The runtime sweeper deletes
# data/logs/<tenant>/runs/<date>/*.log + artifact dirs older than this.
AGENTIC_RETENTION_DAYS=30

# ─── Inngest ─────────────────────────────────────────────────────────────
# REQUIRED in production. Both keys must match the broker's keys.
# Generate via: `openssl rand -hex 32`.
INNGEST_EVENT_KEY=replace-with-32-byte-hex
INNGEST_SIGNING_KEY=signkey-prod-replace-with-32-byte-hex

# Where the API points its event-sender. Inside compose this is the
# broker container's hostname.
INNGEST_BASE_URL=http://inngest:8288

# `INNGEST_DEV=1` switches the sdk to "dev mode" (loose signature checks,
# verbose logging). MUST be unset/blank in production.
# INNGEST_DEV=1

# Cron schedule for the platform sweepers (retention etc.).
# Format: standard 5-field cron. Set AGENTIC_SYSTEM_CRON_DISABLED=1 to
# disable the sweep entirely (e.g. in offline test environments).
AGENTIC_SYSTEM_CRON=0 3 * * *
# AGENTIC_SYSTEM_CRON_DISABLED=1

# ─── Magic-link auth (when AUTH_MODE=production) ─────────────────────────
# Required when sign-in is wired (Phase 2+). Leave blank if your auth
# flow is otherwise (SSO / bearer-tokens-only). The session secret must
# be ≥ 32 bytes — rotate by issuing a new value + a graceful migration.
RESEND_API_KEY=
AUTH_FROM_EMAIL=noreply@operator.example.com
AUTH_SESSION_SECRET=replace-with-32-byte-hex
JWT_SECRET=replace-with-32-byte-hex

# ─── Webhook HMAC secrets ────────────────────────────────────────────────
# Per-provider secret used to verify x-signature headers on inbound
# `/v1/webhooks/<provider>` requests. Add one variable per provider you
# enable; the runtime reads `WEBHOOK_HMAC_SECRET_<UPPERCASE_PROVIDER>`.
WEBHOOK_HMAC_SECRET_DEFAULT=replace-with-32-byte-hex
# WEBHOOK_HMAC_SECRET_GITHUB=
# WEBHOOK_HMAC_SECRET_STRIPE=

# ─── Future BYOK / KMS ───────────────────────────────────────────────────
# Reserved for tenant-bring-your-own-keys encryption. v1 stores LLM
# provider keys as plain env; v2 will wrap with this key.
# AGENTIC_KMS_KEY=

# ─── LLM gateway defaults ────────────────────────────────────────────────
# REQUIRED if you want the gateway to default to a real provider.
# `mock` never makes a network call.
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-3-5-sonnet-latest
LLM_REQUEST_TIMEOUT_MS=60000

# ─── LLM provider API keys (set only the providers you use) ──────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_REFERRER=https://operator.example.com
OPENROUTER_APP_TITLE=Agentic Operator
GOOGLE_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# Azure OpenAI (all three required when used)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=

# Custom OpenAI-compatible endpoint (self-hosted vLLM, etc.)
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=

# ─── Observability ───────────────────────────────────────────────────────
# `/metrics` is unauthenticated by design. Restrict access via a reverse
# proxy ACL or by binding the API to a private network. Documented in
# `docs/RUNBOOK.md §6`.
