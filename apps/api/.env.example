# --- Runtime mode ---
NODE_ENV=development
AUTH_MODE=dev
AGENTIC_DEV_TENANT=raas

# --- Demo mode (locked 2026-05-26) ---
# false → production: no seed, no demo loop, real api only
# true  → demo: seed:rich + periodic synthetic events from demo-runner
AGENTIC_DEMO_MODE=false

# Demo-runner cadence (only consulted when AGENTIC_DEMO_MODE=true).
# Defaults: tick=30_000, taskResolve=90_000, heartbeat=300_000,
#           backpressure=25 active runs.
# AGENTIC_DEMO_TICK_MS=30000
# AGENTIC_DEMO_TASK_RESOLVE_MS=90000
# AGENTIC_DEMO_HEARTBEAT_MS=300000
# AGENTIC_DEMO_RUN_BACKPRESSURE=25

# --- HTTP ---
PORT=3501
HOST=0.0.0.0
WEB_ORIGIN=http://localhost:3599   # CORS allow-list (web app)

# --- SQLite ---
DATABASE_URL=file:../../data/agentic.db

# --- File storage roots ---
AGENTIC_LOGS_DIR=../../data/logs
AGENTIC_ARTIFACTS_DIR=../../data/artifacts
AGENTIC_MODELS_DIR=/Users/kenny/CSI-AICOE/agentic-operator/models

# --- Inngest ---
INNGEST_DEV=1
INNGEST_EVENT_KEY=local-dev-event-key
INNGEST_SIGNING_KEY=local-dev-signing-key
INNGEST_BASE_URL=http://localhost:8288

# --- Magic-link auth (production only) ---
RESEND_API_KEY=
AUTH_FROM_EMAIL=noreply@example.com

# --- Webhook HMAC secrets ---
WEBHOOK_HMAC_SECRET_DEFAULT=local-dev-hmac
