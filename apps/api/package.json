{
  "name": "@agentic/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env --env-file=.env.local src/server.ts",
    "start": "tsx --env-file=../../.env --env-file=.env.local src/server.ts",
    "typecheck": "tsc --noEmit",
