    "@agentic/contracts": "workspace:*",
    "@agentic/db": "workspace:*",
    "@agentic/llm-gateway": "workspace:*",
    "@agentic/runtime": "workspace:*",
    "@agentic/shared": "workspace:*",
    "@agentic/tools": "workspace:*",
    "@tenants/__system": "workspace:*",
    "@tenants/raas": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "inngest": "4.4.0",
    "jose": "^5.10.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.22.0",
